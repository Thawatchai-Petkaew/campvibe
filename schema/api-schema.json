{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "Campground": {
            "type": "object",
            "required": [
                "id",
                "nameTh",
                "nameThSlug",
                "campgroundType",
                "latitude",
                "longitude"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "nameTh": {
                    "type": "string"
                },
                "nameEn": {
                    "type": "string"
                },
                "nameThSlug": {
                    "type": "string"
                },
                "nameEnSlug": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "campgroundType": {
                    "type": "string",
                    "enum": [
                        "CAGD",
                        "CACP",
                        "GLAMP"
                    ]
                },
                "accessTypes": {
                    "type": "string"
                },
                "accommodationTypes": {
                    "type": "string"
                },
                "facilities": {
                    "type": "string"
                },
                "latitude": {
                    "type": "number"
                },
                "longitude": {
                    "type": "number"
                },
                "checkInTime": {
                    "type": "string"
                },
                "checkOutTime": {
                    "type": "string"
                },
                "bookingMethod": {
                    "type": "string",
                    "enum": [
                        "ONLI",
                        "ONCA",
                        "ONST"
                    ]
                },
                "priceLow": {
                    "type": "number"
                },
                "priceHigh": {
                    "type": "number"
                },
                "isVerified": {
                    "type": "boolean"
                },
                "isActive": {
                    "type": "boolean"
                },
                "isPublished": {
                    "type": "boolean"
                }
            }
        },
        "Booking": {
            "type": "object",
            "required": [
                "campgroundId",
                "userId",
                "checkInDate",
                "checkOutDate",
                "guests"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "campgroundId": {
                    "type": "string",
                    "format": "uuid"
                },
                "userId": {
                    "type": "string",
                    "format": "uuid"
                },
                "siteId": {
                    "type": "string",
                    "format": "uuid"
                },
                "checkInDate": {
                    "type": "string",
                    "format": "date"
                },
                "checkOutDate": {
                    "type": "string",
                    "format": "date"
                },
                "guests": {
                    "type": "integer",
                    "minimum": 1
                },
                "totalPrice": {
                    "type": "number"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "PENDING",
                        "CONFIRMED",
                        "CANCELLED"
                    ]
                }
            }
        },
        "Review": {
            "type": "object",
            "required": [
                "campgroundId",
                "authorId",
                "rating",
                "content"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "campgroundId": {
                    "type": "string",
                    "format": "uuid"
                },
                "authorId": {
                    "type": "string",
                    "format": "uuid"
                },
                "rating": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                },
                "title": {
                    "type": "string"
                },
                "content": {
                    "type": "string",
                    "minLength": 10
                },
                "visitDate": {
                    "type": "string",
                    "format": "date"
                }
            }
        },
        "User": {
            "type": "object",
            "required": [
                "email"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "email": {
                    "type": "string",
                    "format": "email"
                },
                "name": {
                    "type": "string"
                },
                "role": {
                    "type": "string",
                    "enum": [
                        "ADMIN",
                        "OPERATOR",
                        "CAMPER"
                    ]
                }
            }
        }
    },
    "enums": {
        "CampgroundType": {
            "CAGD": "Campground",
            "CACP": "Car Camping",
            "GLAMP": "Glamping"
        },
        "AccessType": {
            "BAOT": "Boat Access",
            "DRIV": "Drive-in",
            "HIKE": "Hike-in",
            "BIKE": "Bike-in"
        },
        "AccommodationType": {
            "TENT": "Tent",
            "CABI": "Cabin",
            "TRAI": "Trailer",
            "GLAM": "Glamping"
        },
        "FacilityCode": {
            "TOIL": "Toilet",
            "SHOW": "Shower",
            "WIFI": "Wifi",
            "KITC": "Kitchen",
            "PARK": "Parking",
            "FIRE": "Fire Pit",
            "WATR": "Drinking Water",
            "SECU": "Security"
        },
        "BookingMethod": {
            "ONLI": "Online",
            "ONCA": "On Call",
            "ONST": "On Site"
        },
        "BookingStatus": {
            "PENDING": "Pending",
            "CONFIRMED": "Confirmed",
            "CANCELLED": "Cancelled"
        },
        "UserRole": {
            "ADMIN": "Administrator",
            "OPERATOR": "Campground Operator",
            "CAMPER": "Camper/Guest"
        }
    },
    "endpoints": {
        "GET /api/campsites/[id]/availability": {
            "story": "CAM-190 (AVAIL-1)",
            "auth": "public for public campsites (isActive+isPublished+deletedAt:null); authenticated (operator/admin) for non-public — non-public returns 404 to avoid information-disclosure",
            "cacheDirective": "Cache-Control: no-store (explicit header on response) + export const dynamic = 'force-dynamic' on the route module",
            "input": {
                "id": "string (path param) — campSiteId",
                "startDate": "ISO date string (query) — range start",
                "endDate": "ISO date string (query) — range end"
            },
            "output": {
                "campSiteId": "string",
                "availability": "AvailabilityDay[]",
                "limits": {
                    "maxGuestsPerDay": "number | null",
                    "maxTentsPerDay": "number | null"
                }
            },
            "outputTypes": {
                "AvailabilityDay": {
                    "date": "string (YYYY-MM-DD)",
                    "bookedGuests": "number",
                    "bookedTents": "number",
                    "maxGuests": "number | null",
                    "maxTents": "number | null",
                    "available": "boolean — false when capacity-full OR blocked by host",
                    "remainingGuests": "number | null",
                    "remainingTents": "number | null",
                    "blockedByHost": "boolean — true when a BlockedDate covers this day (NEW CAM-190)",
                    "blockedReason": "string | null — host-authored reason from BlockedDate.reason (NEW CAM-190)"
                }
            },
            "errors": {
                "400": "missing or invalid startDate / endDate — { error: string }",
                "401": "N/A — public endpoint (non-public returns 404)",
                "403": "N/A — non-public silently returns 404",
                "404": "campsite not found or not visible to the caller — { error: string }",
                "409": "N/A — read-only",
                "500": "internal — generic message only; detail logged server-side"
            },
            "errorShape": "{ error: string }",
            "queryStrategy": "3 queries: prisma.campSite.findUnique (visibility check) + prisma.booking.findMany (range) + prisma.blockedDate.findMany (range, identical predicate to POST /api/bookings CAM-57 lines 93-104). No N+1.",
            "availabilityMergeRule": "available=false when (maxGuestsPerDay && bookedGuests >= maxGuestsPerDay) OR (maxTentsPerDay && bookedTents >= maxTentsPerDay) OR blockedByHost===true",
            "blockedDatePredicate": "campSiteId + deletedAt:null + OR[spotId:null, spotId:spotId(if provided)] + AND[startDate:{lte:endDate}, endDate:{gte:startDate}] — mirrors app/api/bookings/route.ts lines 93-104"
        },
        "GET /api/campgrounds/[id]/availability": {
            "story": "CAM-190 (AVAIL-1)",
            "note": "Structurally identical to GET /api/campsites/[id]/availability above; output key is 'campgroundId' instead of 'campSiteId'",
            "auth": "same visibility gate as campsites route",
            "cacheDirective": "Cache-Control: no-store + export const dynamic = 'force-dynamic'",
            "input": {
                "id": "string (path param) — campSiteId",
                "startDate": "ISO date string (query)",
                "endDate": "ISO date string (query)"
            },
            "output": {
                "campgroundId": "string",
                "availability": "AvailabilityDay[] — same shape as campsites route",
                "limits": {
                    "maxGuestsPerDay": "number | null",
                    "maxTentsPerDay": "number | null"
                }
            },
            "errors": {
                "400": "missing or invalid startDate / endDate",
                "401": "N/A",
                "403": "N/A",
                "404": "campground not found or not visible",
                "409": "N/A",
                "500": "internal"
            },
            "errorShape": "{ error: string }",
            "queryStrategy": "same as campsites route — 3 queries, no N+1"
        },
        "POST /api/vitals": {
            "story": "CAM-187 (MEAS-1)",
            "auth": "unauthenticated (public telemetry — browser sendBeacon, no session required)",
            "rateLimit": "200 req / 15 min per IP (in-process, best-effort — lib/rate-limit.ts)",
            "input": {
                "name": "enum: LCP | INP | CLS | TTFB | FCP",
                "value": "number (finite, nonnegative) — milliseconds or unitless depending on metric",
                "rating": "enum: good | needs-improvement | poor",
                "id": "string max 64 — web-vitals attribution id (not PII)",
                "navigationType": "string max 32 optional — navigate | reload | back-forward",
                "routeTemplate": "string max 200 — path pattern with dynamic segments replaced, e.g. /camps/[slug]. NEVER the raw URL with real IDs."
            },
            "output": {
                "success": "204 No Content — empty body (fire-and-forget)"
            },
            "sideEffect": "emits one structured JSON log line per request: { level, event:'cwv_vital', metric, value, rating, routeTemplate, navigationType, deployShA, vitalsId }. No Prisma write. No DB.",
            "pii": "none — IP used only as rate-limit key, never logged",
            "errors": {
                "204": "success — no body",
                "400": "zod validation failed — { error: { code: 'VALIDATION_ERROR', message: string } }",
                "429": "rate limit exceeded — { error: { code: 'RATE_LIMITED', retryAfter: number } }",
                "500": "internal — generic message only; detail logged server-side",
                "401": "N/A — public endpoint",
                "403": "N/A — public endpoint",
                "404": "N/A — no resource fetched",
                "409": "N/A — no resource created"
            },
            "errorShape": "{ error: { code: string, message: string } } (standard) | empty for 204",
            "validationSchema": "lib/validations/vitals.ts (VitalPayloadSchema)",
            "queryStrategy": "no DB query"
        }
    }
}