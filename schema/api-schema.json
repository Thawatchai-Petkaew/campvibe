{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "Campground": {
            "type": "object",
            "required": [
                "id",
                "nameTh",
                "nameThSlug",
                "campgroundType",
                "latitude",
                "longitude"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "nameTh": {
                    "type": "string"
                },
                "nameEn": {
                    "type": "string"
                },
                "nameThSlug": {
                    "type": "string"
                },
                "nameEnSlug": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "campgroundType": {
                    "type": "string",
                    "enum": [
                        "CAGD",
                        "CACP",
                        "GLAMP"
                    ]
                },
                "accessTypes": {
                    "type": "string"
                },
                "accommodationTypes": {
                    "type": "string"
                },
                "facilities": {
                    "type": "string"
                },
                "latitude": {
                    "type": "number"
                },
                "longitude": {
                    "type": "number"
                },
                "checkInTime": {
                    "type": "string"
                },
                "checkOutTime": {
                    "type": "string"
                },
                "bookingMethod": {
                    "type": "string",
                    "enum": [
                        "ONLI",
                        "ONCA",
                        "ONST"
                    ]
                },
                "priceLow": {
                    "type": "number"
                },
                "priceHigh": {
                    "type": "number"
                },
                "isVerified": {
                    "type": "boolean"
                },
                "isActive": {
                    "type": "boolean"
                },
                "isPublished": {
                    "type": "boolean"
                }
            }
        },
        "Booking": {
            "type": "object",
            "required": [
                "campgroundId",
                "userId",
                "checkInDate",
                "checkOutDate",
                "guests"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "campgroundId": {
                    "type": "string",
                    "format": "uuid"
                },
                "userId": {
                    "type": "string",
                    "format": "uuid"
                },
                "siteId": {
                    "type": "string",
                    "format": "uuid"
                },
                "checkInDate": {
                    "type": "string",
                    "format": "date"
                },
                "checkOutDate": {
                    "type": "string",
                    "format": "date"
                },
                "guests": {
                    "type": "integer",
                    "minimum": 1
                },
                "totalPrice": {
                    "type": "number"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "PENDING",
                        "CONFIRMED",
                        "CANCELLED"
                    ]
                }
            }
        },
        "Review": {
            "type": "object",
            "required": [
                "campgroundId",
                "authorId",
                "rating",
                "content"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "campgroundId": {
                    "type": "string",
                    "format": "uuid"
                },
                "authorId": {
                    "type": "string",
                    "format": "uuid"
                },
                "rating": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                },
                "title": {
                    "type": "string"
                },
                "content": {
                    "type": "string",
                    "minLength": 10
                },
                "visitDate": {
                    "type": "string",
                    "format": "date"
                }
            }
        },
        "User": {
            "type": "object",
            "required": [
                "email"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "email": {
                    "type": "string",
                    "format": "email"
                },
                "name": {
                    "type": "string"
                },
                "role": {
                    "type": "string",
                    "enum": [
                        "ADMIN",
                        "OPERATOR",
                        "CAMPER"
                    ]
                }
            }
        }
    },
    "enums": {
        "CampgroundType": {
            "CAGD": "Campground",
            "CACP": "Car Camping",
            "GLAMP": "Glamping"
        },
        "AccessType": {
            "BAOT": "Boat Access",
            "DRIV": "Drive-in",
            "HIKE": "Hike-in",
            "BIKE": "Bike-in"
        },
        "AccommodationType": {
            "TENT": "Tent",
            "CABI": "Cabin",
            "TRAI": "Trailer",
            "GLAM": "Glamping"
        },
        "FacilityCode": {
            "TOIL": "Toilet",
            "SHOW": "Shower",
            "WIFI": "Wifi",
            "KITC": "Kitchen",
            "PARK": "Parking",
            "FIRE": "Fire Pit",
            "WATR": "Drinking Water",
            "SECU": "Security"
        },
        "BookingMethod": {
            "ONLI": "Online",
            "ONCA": "On Call",
            "ONST": "On Site"
        },
        "BookingStatus": {
            "PENDING": "Pending",
            "CONFIRMED": "Confirmed",
            "CANCELLED": "Cancelled"
        },
        "UserRole": {
            "ADMIN": "Administrator",
            "OPERATOR": "Campground Operator",
            "CAMPER": "Camper/Guest"
        }
    },
    "endpoints": {
        "POST /api/vitals": {
            "story": "CAM-187 (MEAS-1)",
            "auth": "unauthenticated (public telemetry — browser sendBeacon, no session required)",
            "rateLimit": "200 req / 15 min per IP (in-process, best-effort — lib/rate-limit.ts)",
            "input": {
                "name": "enum: LCP | INP | CLS | TTFB | FCP",
                "value": "number (finite, nonnegative) — milliseconds or unitless depending on metric",
                "rating": "enum: good | needs-improvement | poor",
                "id": "string max 64 — web-vitals attribution id (not PII)",
                "navigationType": "string max 32 optional — navigate | reload | back-forward",
                "routeTemplate": "string max 200 — path pattern with dynamic segments replaced, e.g. /camps/[slug]. NEVER the raw URL with real IDs."
            },
            "output": {
                "success": "204 No Content — empty body (fire-and-forget)"
            },
            "sideEffect": "emits one structured JSON log line per request: { level, event:'cwv_vital', metric, value, rating, routeTemplate, navigationType, deployShA, vitalsId }. No Prisma write. No DB.",
            "pii": "none — IP used only as rate-limit key, never logged",
            "errors": {
                "204": "success — no body",
                "400": "zod validation failed — { error: { code: 'VALIDATION_ERROR', message: string } }",
                "429": "rate limit exceeded — { error: { code: 'RATE_LIMITED', retryAfter: number } }",
                "500": "internal — generic message only; detail logged server-side",
                "401": "N/A — public endpoint",
                "403": "N/A — public endpoint",
                "404": "N/A — no resource fetched",
                "409": "N/A — no resource created"
            },
            "errorShape": "{ error: { code: string, message: string } } (standard) | empty for 204",
            "validationSchema": "lib/validations/vitals.ts (VitalPayloadSchema)",
            "queryStrategy": "no DB query"
        }
    }
}