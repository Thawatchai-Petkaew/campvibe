# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!env.example

# sqlite (local dev artifacts / accidental files)
*.db
*.db-journal
/prisma/*.db
/prisma/*.db-journal

# vercel
.vercel

# claude code — personal settings (not shared)
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# local uploads
/public/uploads*

# utility scripts (local) — but track the Linear sync CLI used by CI + hooks
/scripts/*
!/scripts/linear-sync.mjs
!/scripts/db-reset.mjs
!/scripts/check-palette.mjs
!/scripts/check-ds.mjs
.claude/linear-snapshot.json

# local design source (large binaries; runtime copies live in public/status-map/)
/design/
# local font working dir (not wired; app uses next/font/google)
/public/fonts/
