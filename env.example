# NextAuth / Auth.js
# Generate a strong secret: `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-strong-secret"

# Database (PostgreSQL)
# Example (local):
# DATABASE_URL="postgresql://postgres:password@localhost:5432/campvibe?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# Optional: Vercel Blob Storage (if using uploads)
BLOB_READ_WRITE_TOKEN=""

# --- Public live status dashboard (/status) ---
# Linear personal API key (Settings > Security & access > Personal API keys) — server-side only
LINEAR_API_KEY=
# Token to protect /status (visit /status?token=...)
STATUS_TOKEN=
# (optional) Linear team key, default CAM
LINEAR_TEAM_KEY=CAM
