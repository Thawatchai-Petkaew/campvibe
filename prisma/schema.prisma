// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums based on 'Option v1'
// Note: SQLite doesn't enforce Enums natively, Prisma handles them as Strings.

// Team & Permission System Enums
enum TeamRole {
  OWNER // ผู้สร้าง - Full access
  ADMIN // ผู้ดูแลระบบ - Almost full access
  MANAGER // ผู้จัดการ - Manage bookings, view analytics
  STAFF // พนักงาน - View and update bookings only
  VIEWER // ผู้ดู - Read-only access
}

enum Permission {
  // Campsite Management
  CAMPSITE_VIEW
  CAMPSITE_UPDATE
  CAMPSITE_DELETE

  // Booking Management
  BOOKING_VIEW
  BOOKING_UPDATE
  BOOKING_CREATE
  BOOKING_DELETE

  // Team Management
  TEAM_VIEW
  TEAM_INVITE
  TEAM_UPDATE_ROLE
  TEAM_REMOVE

  // Analytics
  ANALYTICS_VIEW

  // Financial
  FINANCIAL_VIEW
}

// Domain state enums — closed sets (see docs/adr/ADR-003). Open taxonomies
// (facilities, activities, terrain, campSiteType) stay in MasterData (normalized in S4).
enum UserRole {
  ADMIN
  OPERATOR
  CAMPER
}

enum BusinessType {
  INDIVIDUAL
  COMPANY
  PARTNERSHIP
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  RESUBMIT
}

enum BookingMethod {
  ONLI // Online
  ONCA // On Call
  ONST // On Site
}

enum OwnershipType {
  PRIVATE
  NATIONAL_PARK
}

enum ViewType {
  GENERAL
  RIVER
  MOUNTAIN
  LAKE
  FOREST
  BEACH
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  COMPLETED
}

// Field classification convention (Atomic Data Framework — docs/adr): sensitive fields tagged
// inline [PII] / [Financial] / [Geo] (PDPA-sensitive ⊂ PII); untagged = [Public].
// Business Sets carry deletedAt (soft-delete) + version (optimistic concurrency).
model User {
  id       String  @id @default(uuid())
  email    String  @unique // [PII]
  password String? // Hashed password for credentials auth [PII]
  name     String? // [PII]
  image    String? // Profile image URL
  phone    String? // Contact phone number [PII]
  role     UserRole @default(CAMPER)

  // Host Registration & KYC
  isHostRegistered   Boolean   @default(false)
  hostRegisteredAt   DateTime?
  kycStatus          KycStatus?
  kycSubmittedAt     DateTime?
  kycApprovedAt      DateTime?
  kycRejectedAt      DateTime?
  kycRejectionReason String?
  kycReviewedBy      String?
  kycDocuments       String? // JSON array [PII]

  // Business Information
  businessName    String?
  businessType    BusinessType?
  taxId           String? // [PII]
  businessAddress String? // [PII]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  campSites       CampSite[] // Operator's camp sites (legacy - as owner)
  teamMemberships CampSiteTeamMember[] // Team memberships across camp sites
  reviews         Review[] // User's reviews
  bookings        Booking[] // User's bookings
  wishlists       Wishlist[] // User's wishlisted camp sites

  @@index([email])
  @@index([kycStatus])
  @@index([isHostRegistered])
}

model ThailandLocation {
  id             String  @id @default(uuid())
  provinceCode   String // e.g., "10" for Bangkok
  provinceName   String // "กรุงเทพมหานคร"
  provinceNameEn String // "Bangkok"
  districtCode   String? // e.g., "1001"
  districtName   String? // "เขตพระนคร"
  districtNameEn String? // "Phra Nakhon"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations Location[]

  @@unique([provinceCode, districtCode])
  @@index([provinceName, districtName])
}

model Location {
  id          String  @id @default(uuid())
  country     String  @default("Thailand")
  region      String?
  province    String?
  district    String?
  subDistrict String?
  village     String?
  lat         Float?
  lon         Float?

  // Link to Thailand administrative division
  thaiLocationId String?
  thaiLocation   ThailandLocation? @relation(fields: [thaiLocationId], references: [id])

  campSites CampSite[]

  @@index([thaiLocationId])
}

model CampSite {
  id          String  @id @default(uuid())
  // Core Identification
  nameTh      String
  nameEn      String?
  nameThSlug  String  @unique
  nameEnSlug  String  @unique
  description String?

  // Classification
  campSiteType String // Relation to MasterData code (e.g. CAGD)

  // Media
  logo     String? // Logo URL
  images   String? // CSV of image URLs
  videoUrl String? // "VDO"

  // Legacy arrays (to be migrated to MasterData relations)
  accessTypes        String
  accommodationTypes String
  facilities         String // Internal facilities
  externalFacilities String? // CSV
  equipment          String? // CSV (Equipment for rent)
  activities         String? // CSV
  terrain            String? // CSV 

  // Geolocation & Address
  latitude   Float // [Geo]
  longitude  Float // [Geo]
  address    String? // [Geo]
  directions String?

  // Operations & Info
  checkInTime   String
  checkOutTime  String
  bookingMethod BookingMethod
  feeInfo       String?
  toiletInfo    String?
  minimumAge    Int?

  // Capacity & Ground Type
  maxGuestsPerDay Int? // จำนวนผู้เข้าพักสูงสุดต่อวัน
  maxTentsPerDay  Int? // จำนวนเต็นท์สูงสุดต่อวัน โดยประมาณ
  groundType      String? // JSON: {"STONE": 5, "GRASS": 10, "CONCRETE": 3, "WOOD": 2}

  // Contact Information
  phone              String? // [PII]
  lineId             String?
  facebookUrl        String?
  facebookMessageUrl String?
  tiktokUrl          String?

  // Pricing — Decimal + ISO 4217 currency (ADR-002)
  priceLow      Decimal? @db.Decimal(12, 2) // [Financial]
  priceHigh     Decimal? @db.Decimal(12, 2) // [Financial]
  priceCurrency String   @default("THB") // [Financial] ISO 4217

  // Status & Dates
  isVerified   Boolean   @default(false)
  verifiedDate DateTime?
  isActive     Boolean   @default(true)
  isPublished  Boolean   @default(false)
  publicDate   DateTime?

  tags String? // CSV

  // Additional Info
  partner      String?
  nationalPark String?

  // Ownership & Pricing
  ownershipType OwnershipType? // เอกชน / อุทยานแห่งชาติ
  isFree        Boolean @default(false) // รองรับกรณีที่เป็นลานประเภทฟรีค่าใช้จ่าย

  // Pet & Display Settings
  petFriendly Boolean @default(false) // ข้อมูล pet friendly
  useSpotView Boolean @default(false) // Flag ระบุว่าจะใช้ข้อมูล Display แบบ camp spot หรือไม่

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  // Relations
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  operatorId String
  operator   User   @relation(fields: [operatorId], references: [id])

  spots       Spot[]
  reviews     Review[]
  bookings    Booking[]
  teamMembers CampSiteTeamMember[] // Team members with roles & permissions
  wishlists   Wishlist[] // Users who wishlisted this camp site

  // Options & Features (New Data-Driven Approach)
  options MasterData[]

  @@index([operatorId])
  @@index([locationId])
  @@index([isPublished, deletedAt])
}

model CampSiteTeamMember {
  id String @id @default(uuid())

  // User & CampSite Relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  campSiteId String
  campSite   CampSite @relation(fields: [campSiteId], references: [id], onDelete: Cascade)

  // Role & Permissions
  role        TeamRole @default(VIEWER)
  permissions String[] // Array of Permission enum values

  // Invitation Info
  invitedBy  String? // User ID who invited
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime? // When user accepted invitation

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, campSiteId])
  @@index([campSiteId])
  @@index([userId])
  @@index([role])
}

model MasterData {
  code   String  @id // e.g. "SHOW", "WIFI"
  group  String // e.g. "Internal facility"
  nameTh String
  nameEn String
  icon   String? // Optional icon identifier

  campSites CampSite[]
}

model Spot {
  id            String  @id @default(uuid())
  zone          String? // Zone name
  name          String // Spot name
  images        String? // CSV of image URLs
  viewType      ViewType?
  maxCampers    Int? // Maximum campers
  maxTents      Int? // Maximum tents
  environment   String?
  pricePerNight Decimal  @db.Decimal(12, 2) // Price per night [Financial]
  pricePerSite  Decimal? @db.Decimal(12, 2) // [Financial]
  priceCurrency String   @default("THB") // [Financial] ISO 4217

  nearFacilities String? // CSV of Internal Facility codes

  campSiteId String
  campSite   CampSite  @relation(fields: [campSiteId], references: [id])
  bookings   Booking[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  @@index([campSiteId])
}

model Review {
  id      String  @id @default(uuid())
  title   String?
  content String?
  rating  Int

  visitDate DateTime?

  mediaUrls String? // CSV of image URLs

  campSiteId String
  campSite   CampSite @relation(fields: [campSiteId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  @@index([campSiteId])
  @@index([authorId])
  @@index([rating])
}

model Booking {
  id String @id @default(uuid())

  checkInDate  DateTime
  checkOutDate DateTime
  guests       Int      @default(1)
  totalPrice   Decimal  @db.Decimal(12, 2) // [Financial]
  currency     String   @default("THB") // [Financial] ISO 4217

  // --- Crystallized snapshot (ADR-005): frozen at create/confirm; host edits to the
  // live camp/spot never mutate these. A booking is an immutable financial document.
  snapshotCampName       String? // camp name (TH) at booking time
  snapshotCampNameEn     String? // camp name (EN) at booking time
  snapshotSpotName       String? // booked spot/unit name at booking time (spot-level bookings)
  snapshotUnitAmount     Decimal? @db.Decimal(12, 2) // [Financial] per-night price charged
  snapshotSubtotalAmount Decimal? @db.Decimal(12, 2) // [Financial]
  snapshotTaxRate        Decimal? @db.Decimal(5, 4) // [Financial] region VAT rate applied
  snapshotTaxAmount      Decimal? @db.Decimal(12, 2) // [Financial]
  snapshotVatInclusive   Boolean? // was the recorded total VAT-inclusive (false until S5 wires Country.vatRate)
  snapshotTotalAmount    Decimal? @db.Decimal(12, 2) // [Financial] legal amount owed
  snapshotCurrency       String? // [Financial] ISO 4217 charged
  snapshotNights         Int?
  snapshotCheckInTime    String? // local wall-clock at booking time
  snapshotCheckOutTime   String?
  snapshotTimezone       String? // IANA (defaults Asia/Bangkok until S5 per-camp tz)

  status BookingStatus @default(CONFIRMED)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  campSiteId String
  campSite   CampSite @relation(fields: [campSiteId], references: [id])

  spotId String?
  spot   Spot?   @relation(fields: [spotId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  @@index([userId])
  @@index([campSiteId])
  @@index([spotId])
  @@index([status])
  @@index([checkInDate, checkOutDate])
}

model Wishlist {
  id         String   @id @default(uuid())
  userId     String
  campSiteId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campSite   CampSite @relation(fields: [campSiteId], references: [id], onDelete: Cascade)

  @@unique([userId, campSiteId])
  @@index([userId])
  @@index([campSiteId])
}

// Singleton config for the AI delivery team (toggled from /status or `/camper-agent on|off`).
// autonomousMode ON = the Camper Agent decides gates G1–G4 on the owner's behalf and only
// escalates G5 / security / irreversible / any monetary cost.
model DeliveryConfig {
  id             String   @id @default("singleton")
  autonomousMode Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  updatedBy      String?
}
