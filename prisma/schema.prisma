// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums based on 'Option v1'
// Note: SQLite doesn't enforce Enums natively, Prisma handles them as Strings.

// Team & Permission System Enums
enum TeamRole {
  OWNER // ผู้สร้าง - Full access
  ADMIN // ผู้ดูแลระบบ - Almost full access
  MANAGER // ผู้จัดการ - Manage bookings, view analytics
  STAFF // พนักงาน - View and update bookings only
  VIEWER // ผู้ดู - Read-only access
}

enum Permission {
  // Campsite Management
  CAMPSITE_VIEW
  CAMPSITE_UPDATE
  CAMPSITE_DELETE

  // Booking Management
  BOOKING_VIEW
  BOOKING_UPDATE
  BOOKING_CREATE
  BOOKING_DELETE

  // Team Management
  TEAM_VIEW
  TEAM_INVITE
  TEAM_UPDATE_ROLE
  TEAM_REMOVE

  // Analytics
  ANALYTICS_VIEW

  // Financial
  FINANCIAL_VIEW
}

// Domain state enums — closed sets (see docs/adr/ADR-003). Open taxonomies
// (facilities, activities, terrain, campSiteType) stay in MasterData (normalized in S4).
enum UserRole {
  ADMIN
  OPERATOR
  CAMPER
}

enum BusinessType {
  INDIVIDUAL
  COMPANY
  PARTNERSHIP
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  RESUBMIT
}

enum BookingMethod {
  ONLI // Online
  ONCA // On Call
  ONST // On Site
}

enum OwnershipType {
  PRIVATE
  NATIONAL_PARK
}

enum ViewType {
  GENERAL
  RIVER
  MOUNTAIN
  LAKE
  FOREST
  BEACH
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  COMPLETED
}

// Field classification convention (Atomic Data Framework — docs/adr): sensitive fields tagged
// inline [PII] / [Financial] / [Geo] (PDPA-sensitive ⊂ PII); untagged = [Public].
// Business Sets carry deletedAt (soft-delete) + version (optimistic concurrency).
model User {
  id       String   @id @default(uuid())
  email    String   @unique // [PII]
  password String? // Hashed password for credentials auth [PII]
  name     String? // [PII]
  image    String? // Profile image URL
  phone    String? // Contact phone number [PII]
  role     UserRole @default(CAMPER)

  // Host Registration & KYC
  isHostRegistered   Boolean    @default(false)
  hostRegisteredAt   DateTime?
  kycStatus          KycStatus?
  kycSubmittedAt     DateTime?
  kycApprovedAt      DateTime?
  kycRejectedAt      DateTime?
  kycRejectionReason String?
  kycReviewedBy      String?
  kycDocuments       String? // JSON array [PII]

  // Business Information
  businessName    String?
  businessType    BusinessType?
  taxId           String? // [PII]
  businessAddress String? // [PII]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  campSites       CampSite[] // Operator's camp sites (legacy - as owner)
  teamMemberships CampSiteTeamMember[] // Team memberships across camp sites
  reviews         Review[] // User's reviews
  bookings        Booking[] // User's bookings
  wishlists       Wishlist[] // User's wishlisted camp sites
  payouts         Payout[] // Operator payouts (S7)
  notifications   Notification[] // User notifications (S7)
  auditLogs       AuditLog[] // Audit events where this user is the actor (S7)

  @@index([email])
  @@index([kycStatus])
  @@index([isHostRegistered])
}

model ThailandLocation {
  id             String  @id @default(uuid())
  provinceCode   String // e.g., "10" for Bangkok
  provinceName   String // "กรุงเทพมหานคร"
  provinceNameEn String // "Bangkok"
  districtCode   String? // e.g., "1001"
  districtName   String? // "เขตพระนคร"
  districtNameEn String? // "Phra Nakhon"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations Location[]

  @@unique([provinceCode, districtCode])
  @@index([provinceName, districtName])
}

// S5 — international region model (ADR-004). Country carries the ISO 3166 code plus the
// regional defaults (currency, locale, timezone, VAT) that make multi-currency/multi-region real.
model Country {
  code            String   @id // ISO 3166-1 alpha-2 (e.g. "TH")
  name            String
  nameLocal       String?
  defaultCurrency String // [Financial] ISO 4217
  defaultLocale   String // BCP-47 (e.g. "th-TH")
  timezone        String // IANA (e.g. "Asia/Bangkok")
  vatRate         Decimal  @db.Decimal(5, 4) // [Financial] standard VAT rate
  createdAt       DateTime @default(now())

  adminAreas AdminArea[]
  locations  Location[]
}

enum AdminLevel {
  PROVINCE
  DISTRICT
  SUBDISTRICT
}

// S5 — self-referential administrative-division tree (the conformant replacement for the flat
// ThailandLocation; ThailandLocation is retained until its consumers migrate). level + national code.
model AdminArea {
  id          String      @id @default(uuid())
  countryCode String
  country     Country     @relation(fields: [countryCode], references: [code])
  level       AdminLevel
  code        String // national admin code (province "10", district "1001")
  nameTh      String
  nameEn      String
  parentId    String?
  parent      AdminArea?  @relation("AdminAreaTree", fields: [parentId], references: [id])
  children    AdminArea[] @relation("AdminAreaTree")
  locations   Location[]
  createdAt   DateTime    @default(now())

  @@unique([countryCode, level, code])
  @@index([countryCode, level])
  @@index([parentId])
}

model Location {
  id          String  @id @default(uuid())
  country     String  @default("Thailand")
  region      String?
  province    String?
  district    String?
  subDistrict String?
  village     String?
  lat         Float? // [Geo]
  lon         Float? // [Geo]

  // S5 — international region links (additive; legacy strings + thaiLocation stay until migrated)
  countryCode String? // [Geo] ISO 3166 (set by seed/app; nullable for forward-safe migration)
  countryRel  Country?   @relation(fields: [countryCode], references: [code])
  adminAreaId String? // [Geo] province/district node in the AdminArea tree
  adminArea   AdminArea? @relation(fields: [adminAreaId], references: [id])

  // Link to Thailand administrative division (legacy — pending migration to adminArea)
  thaiLocationId String?
  thaiLocation   ThailandLocation? @relation(fields: [thaiLocationId], references: [id])

  campSites CampSite[]

  @@index([thaiLocationId])
  @@index([countryCode])
  @@index([adminAreaId])
}

model CampSite {
  id          String  @id @default(uuid())
  // Core Identification
  nameTh      String
  nameEn      String?
  nameThSlug  String  @unique
  nameEnSlug  String  @unique
  description String?

  // Classification
  campSiteType String // Relation to MasterData code (e.g. CAGD)

  // Media
  logo     String? // Logo URL (single, atomic)
  videoUrl String? // "VDO"

  // Accommodation kind — single code (no MasterData group); kept as string for now.
  accommodationTypes String

  // S4a (ADR-003): the multi-value CSV taxonomies — accessTypes, facilities,
  // externalFacilities, equipment, activities, terrain — are now normalized into the
  // `options MasterData[]` relation below, disambiguated by MasterData.group.

  // Geolocation & Address
  latitude   Float // [Geo]
  longitude  Float // [Geo]
  address    String? // [Geo]
  directions String?

  // Operations & Info
  checkInTime   String
  checkOutTime  String
  bookingMethod BookingMethod
  feeInfo       String?
  toiletInfo    String?
  minimumAge    Int?

  // Capacity & Ground Type
  maxGuestsPerDay Int? // จำนวนผู้เข้าพักสูงสุดต่อวัน
  maxTentsPerDay  Int? // จำนวนเต็นท์สูงสุดต่อวัน โดยประมาณ
  groundType      String? // JSON: {"STONE": 5, "GRASS": 10, "CONCRETE": 3, "WOOD": 2}

  // Contact Information
  phone              String? // [PII]
  lineId             String?
  facebookUrl        String?
  facebookMessageUrl String?
  tiktokUrl          String?

  // Pricing — Decimal + ISO 4217 currency (ADR-002)
  priceLow      Decimal? @db.Decimal(12, 2) // [Financial]
  priceHigh     Decimal? @db.Decimal(12, 2) // [Financial]
  priceCurrency String   @default("THB") // [Financial] ISO 4217

  // Status & Dates
  isVerified   Boolean   @default(false)
  verifiedDate DateTime?
  isActive     Boolean   @default(true)
  isPublished  Boolean   @default(false)
  publicDate   DateTime?

  tags String? // CSV

  // Additional Info
  partner      String?
  nationalPark String?

  // Ownership & Pricing
  ownershipType OwnershipType? // เอกชน / อุทยานแห่งชาติ
  isFree        Boolean        @default(false) // รองรับกรณีที่เป็นลานประเภทฟรีค่าใช้จ่าย

  // Pet & Display Settings
  petFriendly Boolean @default(false) // ข้อมูล pet friendly
  useSpotView Boolean @default(false) // Flag ระบุว่าจะใช้ข้อมูล Display แบบ camp spot หรือไม่

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  // AGG-1 (CAM-189): denormalized aggregate — maintained on every review write inside a
  // transaction; recomputed by reconcile job as backstop. Derivation trail:
  //   avgRating   = roundAvgRating(computeAvgRating(non-deleted Review.rating for this camp))
  //   reviewCount = COUNT of non-deleted Review rows for this camp
  // Source: lib/review-summary.ts:roundAvgRating + lib/sort-utils.ts:computeAvgRating
  avgRating   Decimal? @db.Decimal(2, 1) // [Public] null when reviewCount = 0
  reviewCount Int      @default(0)       // [Public]

  // Relations
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  operatorId String
  operator   User   @relation(fields: [operatorId], references: [id])

  spots        Spot[]
  reviews      Review[]
  bookings     Booking[]
  teamMembers  CampSiteTeamMember[] // Team members with roles & permissions
  wishlists    Wishlist[] // Users who wishlisted this camp site
  blockedDates BlockedDate[] // Operator-blocked availability (S7)
  images       Image[] // S4b: media gallery (replaces images CSV)

  // Options & Features (New Data-Driven Approach)
  options MasterData[]

  @@index([operatorId])
  @@index([locationId])
  @@index([isPublished, deletedAt])
  // PERF-2 (CAM-188): composite indexes for catalog price-sort and default/related-sort
  @@index([isPublished, deletedAt, priceLow, id])
  @@index([isPublished, deletedAt, createdAt, id])
  // PERF-5 (CAM-193): composite index for catalog rating-sort at DB (avgRating column, NULLS LAST)
  @@index([isPublished, deletedAt, avgRating, id])
}

model CampSiteTeamMember {
  id String @id @default(uuid())

  // User & CampSite Relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  campSiteId String
  campSite   CampSite @relation(fields: [campSiteId], references: [id], onDelete: Cascade)

  // Role & Permissions
  role        TeamRole @default(VIEWER)
  permissions String[] // Array of Permission enum values

  // Invitation Info
  invitedBy  String? // User ID who invited
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime? // When user accepted invitation

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, campSiteId])
  @@index([campSiteId])
  @@index([userId])
  @@index([role])
}

model MasterData {
  code   String  @id // e.g. "SHOW", "WIFI"
  group  String // e.g. "Internal facility"
  nameTh String
  nameEn String
  icon   String? // Optional icon identifier

  campSites CampSite[]
}

model Spot {
  id            String    @id @default(uuid())
  zone          String? // Zone name
  name          String // Spot name
  viewType      ViewType?
  maxCampers    Int? // Maximum campers
  maxTents      Int? // Maximum tents
  environment   String?
  pricePerNight Decimal   @db.Decimal(12, 2) // Price per night [Financial]
  pricePerSite  Decimal?  @db.Decimal(12, 2) // [Financial]
  priceCurrency String    @default("THB") // [Financial] ISO 4217

  nearFacilities String? // CSV of Internal Facility codes

  campSiteId   String
  campSite     CampSite      @relation(fields: [campSiteId], references: [id])
  bookings     Booking[]
  blockedDates BlockedDate[] // spot-level availability blocks (S7)
  images       Image[] // S4b: spot media gallery

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  @@index([campSiteId])
}

model Review {
  id      String  @id @default(uuid())
  title   String?
  content String?
  rating  Int

  visitDate DateTime?

  campSiteId String
  campSite   CampSite @relation(fields: [campSiteId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  images Image[] // S4b: review photos (replaces mediaUrls CSV)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  @@index([campSiteId])
  @@index([authorId])
  @@index([rating])
}

model Booking {
  id String @id @default(uuid())

  checkInDate  DateTime
  checkOutDate DateTime
  guests       Int      @default(1)
  totalPrice   Decimal  @db.Decimal(12, 2) // [Financial]
  currency     String   @default("THB") // [Financial] ISO 4217

  // --- Crystallized snapshot (ADR-005): frozen at create/confirm; host edits to the
  // live camp/spot never mutate these. A booking is an immutable financial document.
  snapshotCampName       String? // camp name (TH) at booking time
  snapshotCampNameEn     String? // camp name (EN) at booking time
  snapshotSpotName       String? // booked spot/unit name at booking time (spot-level bookings)
  snapshotUnitAmount     Decimal? @db.Decimal(12, 2) // [Financial] per-night price charged
  snapshotSubtotalAmount Decimal? @db.Decimal(12, 2) // [Financial]
  snapshotTaxRate        Decimal? @db.Decimal(5, 4) // [Financial] region VAT rate applied
  snapshotTaxAmount      Decimal? @db.Decimal(12, 2) // [Financial]
  snapshotVatInclusive   Boolean? // was the recorded total VAT-inclusive (false until S5 wires Country.vatRate)
  snapshotTotalAmount    Decimal? @db.Decimal(12, 2) // [Financial] legal amount owed
  snapshotCurrency       String? // [Financial] ISO 4217 charged
  snapshotNights         Int?
  snapshotCheckInTime    String? // local wall-clock at booking time
  snapshotCheckOutTime   String?
  snapshotTimezone       String? // IANA (defaults Asia/Bangkok until S5 per-camp tz)

  status BookingStatus @default(CONFIRMED)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  campSiteId String
  campSite   CampSite @relation(fields: [campSiteId], references: [id])

  spotId String?
  spot   Spot?   @relation(fields: [spotId], references: [id])

  payments Payment[] // Payment ledger for this booking (S7)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete
  version   Int       @default(1)

  @@index([userId])
  @@index([campSiteId])
  @@index([spotId])
  @@index([status])
  @@index([checkInDate, checkOutDate])
}

model Wishlist {
  id         String   @id @default(uuid())
  userId     String
  campSiteId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campSite   CampSite @relation(fields: [campSiteId], references: [id], onDelete: Cascade)

  @@unique([userId, campSiteId])
  @@index([userId])
  @@index([campSiteId])
}

// Singleton config for the AI delivery team (toggled from /status or `/camper-agent on|off`).
// autonomousMode ON = the Camper Agent decides gates G1–G4 on the owner's behalf and only
// escalates G5 / security / irreversible / any monetary cost.
// DEPRECATED — autonomous gate-decision feature removed (interactive-only). Unused; kept to avoid a destructive migration. Do NOT add new readers.
model DeliveryConfig {
  id             String   @id @default("singleton")
  autonomousMode Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  updatedBy      String?
}

// Real-time signal for the /status dashboard (CAM-140). Single row id="singleton";
// `version` is bumped by the Linear webhook on every issue change and polled by the
// SSE stream (app/api/status/stream). No business data — a refresh trigger only.
model StatusPulse {
  id        String   @id @default("singleton")
  version   Int      @default(0)
  updatedAt DateTime @updatedAt
}

// ============================================================================
// S7 — Roadmap seam entities (ADR-006 conventions). Additive foundation for
// payments, payouts, audit trail, availability blocking, and notifications.
// Ledgers (Payment/Payout/AuditLog) are append-only → NO soft-delete.
// Business sets (BlockedDate/Notification) carry deletedAt. Future feature
// stories consume these; no behavioral wiring is added here.
// ============================================================================

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  PROMPTPAY
  BANK_TRANSFER
  CASH
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum NotificationType {
  BOOKING
  PAYMENT
  REVIEW
  SYSTEM
  KYC
}

// Money received against a booking — immutable financial ledger.
model Payment {
  id          String        @id @default(uuid())
  bookingId   String
  booking     Booking       @relation(fields: [bookingId], references: [id])
  amount      Decimal       @db.Decimal(12, 2) // [Financial]
  currency    String        @default("THB") // [Financial] ISO 4217
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  provider    String? // payment gateway name
  providerRef String? // gateway transaction id [Financial]
  paidAt      DateTime?

  // Refund linkage (append-only): a refund is a SEPARATE row pointing at its charge,
  // supporting partial refunds; net = sum(charges) − sum(refunds).
  refundOfId String?
  refundOf   Payment?  @relation("PaymentRefunds", fields: [refundOfId], references: [id])
  refunds    Payment[] @relation("PaymentRefunds")

  // Settlement: which payout swept this payment (null = not yet settled).
  payoutId String?
  payout   Payout? @relation(fields: [payoutId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerRef]) // idempotent gateway-webhook ingestion (NULLs distinct → manual/cash rows unaffected)
  @@index([bookingId])
  @@index([status])
  @@index([providerRef])
  @@index([refundOfId])
  @@index([payoutId])
}

// Payouts to an operator — immutable financial ledger.
model Payout {
  id          String       @id @default(uuid())
  operatorId  String
  operator    User         @relation(fields: [operatorId], references: [id])
  amount      Decimal      @db.Decimal(12, 2) // [Financial]
  currency    String       @default("THB") // [Financial] ISO 4217
  status      PayoutStatus @default(PENDING)
  periodStart DateTime?
  periodEnd   DateTime?
  paidAt      DateTime?
  reference   String? // bank/transfer reference [Financial]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  payments Payment[] // payments swept into this payout (settlement traceability)

  @@index([operatorId])
  @@index([status])
  @@index([reference])
}

// Append-only audit trail. No soft-delete, no updatedAt — records are never mutated.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String? // null = system action
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String // e.g. "booking.status.update"
  entityType String // e.g. "Booking"
  entityId   String
  metadata   Json? // before/after diff or context
  ipAddress  String? // [PII]
  userAgent  String? // [PII] device/browser fingerprint
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// Operator-blocked availability window — business set, soft-deletable.
model BlockedDate {
  id         String    @id @default(uuid())
  campSiteId String
  campSite   CampSite  @relation(fields: [campSiteId], references: [id])
  spotId     String? // null = whole-camp block; set = single spot (mirrors Booking camp/spot duality)
  spot       Spot?     @relation(fields: [spotId], references: [id])
  startDate  DateTime  @db.Date
  endDate    DateTime  @db.Date
  reason     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime? // soft-delete
  version    Int       @default(1)

  @@index([campSiteId])
  @@index([spotId])
  @@index([startDate, endDate])
}

// User-facing notification — business set, soft-deletable.
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType @default(SYSTEM)
  title     String
  body      String?
  link      String? // deep link target
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  deletedAt DateTime? // soft-delete
  version   Int              @default(1)

  @@index([userId, isRead])
  @@index([createdAt])
}

// S4b — media gallery (ADR-006). Polymorphic via nullable FKs: an Image belongs to a
// CampSite, a Spot, or a Review. Replaces the *.images / mediaUrls CSV columns; logo
// stays a single String. sortOrder controls gallery order.
model Image {
  id         String    @id @default(uuid())
  url        String
  alt        String?
  sortOrder  Int       @default(0)
  campSiteId String?
  campSite   CampSite? @relation(fields: [campSiteId], references: [id], onDelete: Cascade)
  spotId     String?
  spot       Spot?     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  reviewId   String?
  review     Review?   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([campSiteId])
  @@index([spotId])
  @@index([reviewId])
}
