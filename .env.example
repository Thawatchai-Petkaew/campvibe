# Database Configuration
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-replace-this"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Vercel Blob Storage (for production image uploads)
# BLOB_READ_WRITE_TOKEN="your-blob-token-here"

# Optional: Email Configuration (for password reset, notifications)
# EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
# EMAIL_FROM="noreply@campvibe.com"

# --- Public live status dashboard (/status) ---
# Linear personal API key (Settings > Security & access > Personal API keys) — server-side only
LINEAR_API_KEY=
# Token to protect /status (visit /status?token=...)
STATUS_TOKEN=
# (optional) Linear team key, default CAM
LINEAR_TEAM_KEY=CAM
