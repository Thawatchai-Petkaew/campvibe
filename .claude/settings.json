{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)"
    ],
    "allow": [
      "Bash(npm run *)",
      "Bash(node scripts/*)",
      "Bash(git *)",
      "Bash(gh *)"
    ],
    "ask": [
      "Bash(vercel *)",
      "Bash(npx vercel *)",
      "Bash(npm run promote*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash",
        "hooks": [ { "type": "command",
          "command": "case \"$CLAUDE_TOOL_INPUT_command\" in *\"git commit\"*) npx --no-install tsc --noEmit && npm run lint || { echo 'BLOCK: lint/typecheck failed'; exit 2; };; esac" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write",
        "hooks": [ { "type": "command",
          "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/palette-guard.sh\"" } ] }
    ],
    "SessionStart": [
      { "hooks": [ { "type": "command",
        "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"" } ] }
    ]
  }
}
